# Local machine configuration for ~/.zshrc.local.
#
# Keep real machine paths, credentials, proxies, and private aliases here.
# This example file is safe to commit because every value is a placeholder.

# ---------------------------------------------------------------------------
# Local binaries
# ---------------------------------------------------------------------------

# export PATH="$HOME/.local/bin:$PATH"
# export PATH="$HOME/<private-bin-dir>:$PATH"

# ---------------------------------------------------------------------------
# Conda or Miniconda
# ---------------------------------------------------------------------------

